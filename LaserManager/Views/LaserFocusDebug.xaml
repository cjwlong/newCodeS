<UserControl x:Class="LaserManager.Views.LaserFocusDebug"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LaserManager.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <!-- 主表 -->
        <DataGrid Grid.Column="0" 
                  ItemsSource="{Binding MainList}"
                  SelectedItem="{Binding SelectedMain}"
                  AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="*" />
                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- 子表 -->
        <DataGrid Grid.Column="1"
                  ItemsSource="{Binding ChildList}"
                  AutoGenerateColumns="False"
                  Margin="10,0,0,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="*" />
                <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- 保存按钮 -->
        <Button Content="保存"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Width="100" Height="35"
                Command="{Binding SaveCommand}"/>
    </Grid>

</UserControl>
