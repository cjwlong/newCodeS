<UserControl x:Class="LaserManager.Views.LaserDebug"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LaserManager.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Grid.Row="0">
            <Label>X位置：</Label>
            <TextBox Width="60" Text="{Binding XAxisPosition}" HorizontalContentAlignment="Center"/>
            <Label>Y位置：</Label>
            <TextBox Width="60" Text="{Binding YAxisPosition}" HorizontalContentAlignment="Center"/>
            <Label>Z位置：</Label>
            <TextBox Width="60" Text="{Binding ZAxisPosition}" HorizontalContentAlignment="Center"/>
            <Label>A位置：</Label>
            <TextBox Width="60" Text="{Binding AAxisPosition}" HorizontalContentAlignment="Center"/>
            <Label>C位置：</Label>
            <TextBox Width="60" Text="{Binding CAxisPosition}" HorizontalContentAlignment="Center"/>
            <Button Content="获取当前位置" Width="120" 
                Command="{Binding GetPosCommand}" Cursor="Hand"/>
            <Label>焦点：</Label>
            <ComboBox Width="90" ItemsSource="{Binding FocusPoint}" SelectedItem="{Binding FocusPosition}" />
            <Button Content="X移动到焦点位" Width="125" Command="{Binding PointFocusCommand}" />
        </StackPanel>

        <!-- 顶部选择区 -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Grid.Row="1">
            <ComboBox Width="150" ItemsSource="{Binding Positions}" SelectedItem="{Binding StartPosition}" />
            <TextBlock Text="———>" VerticalAlignment="Center"/>
            <ComboBox Width="150" ItemsSource="{Binding Positions}" SelectedItem="{Binding EndPosition}" />
            <Label>轴名：</Label>
            <ComboBox Width="150" ItemsSource="{Binding Axes}" SelectedItem="{Binding SelectedAxis}" />
            <Label >是否与上同组：</Label>
            <ComboBox Width="70" ItemsSource="{Binding Gpis}" SelectedItem="{Binding SelectedGroup}" />
            <Label>X安全位置：</Label>
            <TextBox Width="80" Text="{Binding SafeX}"  VerticalAlignment="Center" />
            <Button Content="新增" Width="80" Command="{Binding AddCommand}" />
            <Label Visibility="Hidden" >距离：</Label>
            <TextBox Width="100" Text="{Binding Distance}" VerticalAlignment="Center"  Visibility="Hidden" />
           
        </StackPanel>

        <!-- 表格区 -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding MoveItems}"
                  SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  Margin="0,10,0,0"
                  IsReadOnly="False">

            <DataGrid.Columns>
                <DataGridTextColumn Header="编号" Binding="{Binding Index}" Width="60" IsReadOnly="True"/>
                <DataGridTextColumn Header="组编号" Binding="{Binding GroupNo}" Width="100"/>
                <DataGridTextColumn Header="位置名称(起点)" Binding="{Binding StartPosition}" Width="150" IsReadOnly="True"/>
                <DataGridTextColumn Header="起点" Binding="{Binding StartValuePosition}" Width="150" IsReadOnly="True"/>
                <DataGridTextColumn Header="位置名称(终点)" Binding="{Binding EndPosition}" Width="150" IsReadOnly="True"/>
                <DataGridTextColumn Header="终点" Binding="{Binding EndValuePosition}" Width="150" IsReadOnly="True"/>
                <DataGridTextColumn Header="轴名" Binding="{Binding Axis}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="距离" Binding="{Binding Distance}" Width="100"/>
                <DataGridTextColumn Header="X零点位置" Binding="{Binding XAxisPosition}" Width="100"  Visibility="Hidden"/>
                <DataGridTextColumn Header="Y零点位置" Binding="{Binding YAxisPosition}" Width="100"  Visibility="Hidden"/>
                <DataGridTextColumn Header="Z零点位置" Binding="{Binding ZAxisPosition}" Width="100"  Visibility="Hidden"/>
                <DataGridTextColumn Header="A零点位置" Binding="{Binding AAxisPosition}" Width="100"  Visibility="Hidden"/>
                <DataGridTextColumn Header="C零点位置" Binding="{Binding CAxisPosition}" Width="100"  Visibility="Hidden"/>
                <DataGridTextColumn Header="移动顺序" Binding="{Binding MoveNo}" Width="100"/>
                <DataGridTemplateColumn Header="是否启用" Width="100" >
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsUse, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ></CheckBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="起点" Width="80" Visibility="Hidden">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsStart, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ></CheckBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="终点" Width="80" Visibility="Hidden">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsEnd, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 底部按钮区 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="起点填入" Width="100" Command="{Binding PointStartCommand}" />
            <Button Content="终点填入" Width="100" Command="{Binding PointEndCommand}" />
            <Button Content="计算距离" Width="100" Command="{Binding DisCommand}" />
            <Button Content="保存" Width="100" Command="{Binding SaveCommand}" />
            <Button Content="删除" Width="100" Command="{Binding DeleteCommand}" />
            <Button Content="移动" Width="100" Command="{Binding MoveCommand}" Visibility="Hidden" />
        </StackPanel>
    </Grid>
</UserControl>
