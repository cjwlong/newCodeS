<UserControl x:Class="SharedResource.Views.MessageBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SharedResource.Views"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             MinWidth="250" MinHeight="150"
             MaxHeight="300" MaxWidth="400">
    <prism:Dialog.WindowStyle>
        <Style TargetType="prism:DialogWindow">
            <Setter Property="prism:Dialog.WindowStartupLocation" Value="CenterScreen" />
            <Setter Property="ResizeMode" Value="NoResize"/>
            <Setter Property="ShowInTaskbar" Value="False"/>
            <Setter Property="SizeToContent" Value="WidthAndHeight"/>
            <Setter Property="Topmost" Value="True"/>
        </Style>
    </prism:Dialog.WindowStyle>
    <Grid x:Name="LayoutRoot" Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="17" Text="{Binding Message}" TextAlignment="Center" HorizontalAlignment="Stretch" VerticalAlignment="Center" Grid.Row="0" TextWrapping="Wrap" />
        <StackPanel Height="40" Visibility="Visible" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10,10,5" Grid.Row="1" >
            <Button FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Visible" MinHeight="30" MinWidth="60" Command="{Binding CloseDialogCommand}" CommandParameter="true" Content="OK" Margin="2" IsDefault="True" />
        </StackPanel>
    </Grid>
</UserControl>
