<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style TargetType="GroupBox" x:Key="GroupBoxStyle">
        <Setter Property="Margin" Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Border BorderBrush="#8FC0E2" BorderThickness="0.5" CornerRadius="13">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="14*"/>
                            </Grid.RowDefinitions>
                            <Border BorderBrush="#8FC0E2" BorderThickness="0 0 0 0.5"/>
                            <Ellipse Width="8" Height="8" Fill="Orange" HorizontalAlignment="Left" Margin="10 0 0 0"/>
                            <ContentPresenter ContentSource="Header" TextBlock.Foreground="#00B2EE"
                                          VerticalAlignment="Center" HorizontalAlignment="Left"
                                          Margin="25 0 0 0" TextBlock.FontWeight="Bold" TextBlock.FontSize="14"/>

                            <ContentPresenter Grid.Row="1"/>
                            <Border VerticalAlignment="Top" Grid.Row="0" BorderThickness="6" Margin="0 -6.5">
                                <Border.BorderBrush>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#1EA6D3" Offset="0"/>
                                        <GradientStop Color="Transparent" Offset="0.55"/>
                                    </RadialGradientBrush>
                                </Border.BorderBrush>
                            </Border>

                            <Border VerticalAlignment="Bottom"  Grid.Row="1" BorderThickness="6" Margin="0 -6">
                                <Border.BorderBrush>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#1EA6D3" Offset="0"/>
                                        <GradientStop Color="Transparent" Offset="0.55"/>
                                    </RadialGradientBrush>
                                </Border.BorderBrush>
                            </Border>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>