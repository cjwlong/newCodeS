<UserControl x:Class="ExternalIOManager.Views.IoMonitor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ExternalIOManager.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:converters="clr-namespace:ExternalIOManager.converters"
             xmlns:base_converter="clr-namespace:SharedResource.convertors;assembly=SharedResource"
             prism:ViewModelLocator.AutoWireViewModel="True"
             FontSize="16"
             mc:Ignorable="d" 
             d:DesignHeight="470" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:BooleanToColorConverter x:Key="BooleanToColorConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <base_converter:DeviceStatusToEnableConvertor x:Key="DeviceStatusToEnableConvertor"/>
        <base_converter:DeviceStatusToContentConverter x:Key="DeviceStatusToContentConverter"/>
        <base_converter:DeviceStatusToBooleanConverter x:Key="DeviceStatusToBooleanConverter"/>
        <base_converter:DeviceStatusToVisibilityConvertor x:Key="DeviceStatusToVisibilityConvertor"/>
    </UserControl.Resources>
    <Grid>
        <Border Background="#80e6e6e6" CornerRadius="5" Height="570" VerticalAlignment="Top">
            <StackPanel>
                <Label FontWeight="Heavy" FontSize="21" Margin="0 10">IO 设备</Label>
                
                <StackPanel Orientation="Horizontal" Margin="20 0">
                    <StackPanel Orientation="Horizontal">
                        <Label>I P :</Label>
                        <TextBox BorderBrush="Gray" BorderThickness="1"
                                 Padding="1" MinWidth="100"
                                 Text="{Binding IP}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"></TextBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="31 0">
                        <Label>Port :</Label>
                        <TextBox BorderBrush="Gray" BorderThickness="1"
                                 Padding="1" MinWidth="100"
                                 Text="{Binding Port}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"></TextBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="20 0">
                        <Button Width="100" Height="30"
                                IsEnabled="{Binding DeviceService.DeviceStatus, Converter={StaticResource DeviceStatusToEnableConvertor}}"
                                Command="{Binding ConnectCommand}"
                                Content="{Binding DeviceService.DeviceStatus, Converter={StaticResource DeviceStatusToContentConverter}}"></Button>
                        <ProgressBar IsIndeterminate="True"
                                     Style="{StaticResource MaterialDesignCircularProgressBar}"
                                     Value="70" Margin="5 0"
                                     Visibility="{Binding DeviceService.DeviceStatus, Converter={StaticResource DeviceStatusToVisibilityConvertor}}"></ProgressBar>
                    </StackPanel>
                </StackPanel>

                <!--<StackPanel Orientation="Horizontal" Margin="20 15">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center">调试模式：</TextBlock>
                    <ToggleButton IsChecked="{Binding IsDebug, Mode=OneWayToSource}"
                                  IsEnabled="{Binding DeviceService.DeviceStatus, Converter={StaticResource DeviceStatusToBooleanConverter}}"></ToggleButton>
                </StackPanel>-->

                <Grid Margin="10 20 10 10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="三色灯和警报器监控" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10"/>
                    
                    <Grid Grid.Row="1" Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="0.5*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 左侧：三色灯和警报器 -->
                        <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Right"  VerticalAlignment="Top">
                            <TextBlock Text="设备状态" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                            <!-- 红灯 -->
                            <StackPanel Orientation="Horizontal" Margin="0,10">
                                <Ellipse Width="30" Height="30" Margin="0,0,10,0">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{Binding DeviceStatus.RedLamp, Converter={StaticResource BooleanToColorConverter}, ConverterParameter=Red, FallbackValue=Gray}"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Text="红灯" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- 黄灯 -->
                            <StackPanel Orientation="Horizontal" Margin="0,10">
                                <Ellipse Width="30" Height="30" Margin="0,0,10,0">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{Binding DeviceStatus.YellowLamp, Converter={StaticResource BooleanToColorConverter}, ConverterParameter=Yellow, FallbackValue=Gray}"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Text="黄灯" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- 绿灯 -->
                            <StackPanel Orientation="Horizontal" Margin="0,10">
                                <Ellipse Width="30" Height="30" Margin="0,0,10,0">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{Binding DeviceStatus.GreenLamp, Converter={StaticResource BooleanToColorConverter}, ConverterParameter=Green, FallbackValue=Gray}"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Text="绿灯" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- 警报器 -->
                            <StackPanel Orientation="Horizontal" Margin="0,10">
                                <Ellipse Width="30" Height="30" Margin="0,0,10,0">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{Binding DeviceStatus.Alarm, Converter={StaticResource BooleanToColorConverter}, ConverterParameter=Orange, FallbackValue=Gray}"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Text="警报器" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <!--<StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Left"  VerticalAlignment="Top" Margin="25 0"
                                    Visibility="{Binding IsDebug, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                            <ToggleButton Margin="0,7" Command="{Binding ChangedLigStatusCommand}" CommandParameter="红" IsChecked="{Binding DeviceStatus.RedLamp, Mode=OneWay}"></ToggleButton>
                            <ToggleButton Margin="0,10" Command="{Binding ChangedLigStatusCommand}" CommandParameter="黄" IsChecked="{Binding DeviceStatus.YellowLamp, Mode=OneWay}"></ToggleButton>
                            <ToggleButton Margin="0,10" Command="{Binding ChangedLigStatusCommand}" CommandParameter="绿" IsChecked="{Binding DeviceStatus.GreenLamp, Mode=OneWay}"></ToggleButton>
                            <ToggleButton Margin="0,7" Command="{Binding ChangedLigStatusCommand}" CommandParameter="报警" IsChecked="{Binding DeviceStatus.Alarm, Mode=OneWay}"></ToggleButton>
                        </StackPanel>-->

                            <!-- 右侧：输入状态 -->
                        <StackPanel Grid.Column="2" Orientation="Vertical" HorizontalAlignment="Left"  VerticalAlignment="Top">
                            <TextBlock Text="输入状态" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                            <!-- 急停按钮 -->
                            <StackPanel Orientation="Horizontal" Margin="0,10">
                                <Rectangle Width="30" Height="30" Margin="0,0,10,0" RadiusX="5" RadiusY="5">
                                    <Rectangle.Fill>
                                        <SolidColorBrush Color="{Binding DeviceStatus.EmergencyStop, Converter={StaticResource BooleanToColorConverter}, ConverterParameter=DarkRed, FallbackValue=Gray}"/>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <TextBlock Text="急停按钮" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- 门状态 -->
                            <StackPanel Orientation="Horizontal" Margin="0,10">
                                <Rectangle Width="30" Height="30" Margin="0,0,10,0" RadiusX="5" RadiusY="5">
                                    <Rectangle.Fill>
                                        <SolidColorBrush Color="{Binding DeviceStatus.DoorOpen, Converter={StaticResource BooleanToColorConverter}, ConverterParameter=Blue, FallbackValue=Gray}"/>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <TextBlock Text="门状态" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,10">
                                <Rectangle Width="30" Height="30" Margin="0,0,10,0" RadiusX="5" RadiusY="5">
                                    <Rectangle.Fill>
                                        <SolidColorBrush Color="{Binding DeviceStatus.GasPressure, Converter={StaticResource BooleanToColorConverter}, ConverterParameter=DarkRed, FallbackValue=Gray}"/>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <TextBlock Text="气压状态" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- 底部：控制按钮 -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0" 
                                IsEnabled="{Binding DeviceService.DeviceStatus, Converter={StaticResource DeviceStatusToBooleanConverter}}">
                        <Button Content="开始监控" Command="{Binding StartMonitoringCommand}" Width="120" Height="40" Margin="0,0,20,0"
                                IsEnabled="{Binding IsMonitoring, Converter={StaticResource InverseBooleanConverter}}"/>
                        <Button Content="停止监控" Command="{Binding StopMonitoringCommand}" Width="120" Height="40"
                                IsEnabled="{Binding IsMonitoring}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
