<UserControl x:Class="MenuControl.Views.MenuControlBtn"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MenuControl.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:convertor="clr-namespace:MenuControl.convertors"
             mc:Ignorable="d" 
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <convertor:Status2ResetEnableConvertor x:Key="Status2ResetEnableConvertor"/>
        <convertor:DeviceStatus2BtnIsEnableConvertor x:Key="DeviceStatus2BtnIsEnableConvertor"/>
        <convertor:ProcessStatus2BtnEnabledConverter x:Key="ProcessStatus2BtnEnabledConverter"/>
    </UserControl.Resources>
    <StackPanel Orientation="Horizontal">
        <Grid Width="30"></Grid>
        <Button Style="{StaticResource MaterialDesignFloatingActionLightButton}"
                FontSize="24" Height="70" Width="70"
                Padding="1"
                ToolTip="{Binding Machine.GlobalResetInfo}"
                Background="#BF6b8500"
                Command="{Binding GlobalResetCommand}"
                IsEnabled="{Binding GlobalProcessStatus.ProcessStatus, Converter={StaticResource Status2ResetEnableConvertor}}">复位</Button>
        <Grid Width="30"></Grid>
        <UniformGrid Rows="1" Width="auto" IsEnabled="{Binding GlobalProcessStatus.DeviceStatus, Converter={StaticResource DeviceStatus2BtnIsEnableConvertor}}">
            <Button Style="{StaticResource MaterialDesignFloatingActionLightButton}"
                    FontSize="24" Height="70" Width="70"
                    ToolTip="开始/继续执行刻蚀程序"
                    Margin="10 0"
                    Content="开始"
                    Command="{Binding PublishCommand}"
                    CommandParameter="start"
                    IsEnabled="{Binding GlobalProcessStatus.ProcessStatus, Converter={StaticResource ProcessStatus2BtnEnabledConverter}, ConverterParameter=start}">
            </Button>
            <!--<Button Style="{StaticResource MaterialDesignFloatingActionLightButton}"
                    ToolTip="暂停当前正在执行的可是程序"
                    FontSize="24" Height="70" Width="70"
                    Command="{Binding PublishCommand}"
                    Content="暂停"
                    CommandParameter="pause"
                    IsEnabled="{Binding GlobalProcessStatus.ProcessStatus, Converter={StaticResource ProcessStatus2BtnEnabledConverter}, ConverterParameter=pause}">             
            </Button>-->
            <Button Style="{StaticResource MaterialDesignFloatingActionLightButton}"
                    ToolTip="停止当前正在执行的刻蚀程序"
                    FontSize="24" Height="70" Width="70"
                    Command="{Binding PublishCommand}"
                    CommandParameter="stop"
                    IsEnabled="{Binding GlobalProcessStatus.ProcessStatus, Converter={StaticResource ProcessStatus2BtnEnabledConverter}, ConverterParameter=stop}">停止
            </Button>            
        </UniformGrid>
        <Grid Width="30"></Grid>
        <Button ToolTip="紧急停止所有轴" Background="#e63f32" FontSize="24" Height="70" Width="70" Padding="1"
                Style="{StaticResource MaterialDesignFloatingActionLightButton}"
                Command="{Binding KillAllAxisCommand}">急停</Button>
        <Grid Width="50"></Grid>
        <Button ToolTip="监控接触式位移传感器测量" Background="#BF6b8500" FontSize="24" Height="70" Width="70" Padding="1"  Visibility="Hidden"
        Style="{StaticResource MaterialDesignFloatingActionLightButton}"
        Command="{Binding MeasurementCommand}">测量</Button>
    </StackPanel>    
</UserControl>
