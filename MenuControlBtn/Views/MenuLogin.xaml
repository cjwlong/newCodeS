<UserControl x:Class="MenuControl.Views.MenuLogin"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MenuControl.Views"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:converter="clr-namespace:MenuControl.convertors"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converter:ChangeLogAndDebugConverter x:Key="ChangeLogAndDebugConverter"/>
    </UserControl.Resources>
    
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
        <StackPanel>
            <ToggleButton x:Name="LogAndDebugTBtn" 
                          materialDesign:ToggleButtonAssist.OnContent="{materialDesign:PackIcon Kind=DebugStepOver, Size=37}"
                          Content="{materialDesign:PackIcon Kind=MathLog, Size=40}"
                          Style="{StaticResource MaterialDesignActionToggleButton}"
                          Background="#bababa"
                          BorderThickness="1"
                          Height="45" Width="45" Margin="0 10 20 5"
                          Command="{Binding ChangeLogAndDebugModeCommand}" 
                          CommandParameter="{Binding IsChecked, RelativeSource={RelativeSource Self}}">
            </ToggleButton>
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                       Text="{Binding ElementName=LogAndDebugTBtn, Path=IsChecked, Mode=OneWay, Converter={StaticResource ChangeLogAndDebugConverter}}"
                       Margin="0 0 20 0"
                       FontSize="13"></TextBlock>
        </StackPanel>

        <StackPanel>
            <Button Height="45" Width="45" Margin="10 10 20 5"
            FontSize="20" Padding="1"
            ToolTip="打开操作文档"
            Style="{StaticResource MaterialDesignFlatDarkButton}"
            Command="{Binding OpenHelpHandbookCommand}">
                <materialDesign:PackIcon Kind="CommentQuestionOutline" Height="40" Width="40"/>
            </Button>
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Margin="0 0 10 0">帮助</TextBlock>
        </StackPanel>
    </StackPanel>
    
</UserControl>
