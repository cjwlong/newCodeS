<UserControl x:Class="DiastimeterManager.Views.LaserRangeSetting"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DiastimeterManager.Views"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:base_convertor="clr-namespace:SharedResource.convertors;assembly=SharedResource"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             FontSize="15"
             d:DesignHeight="500" d:DesignWidth="800">
    <UserControl.Resources>
        <base_convertor:DeviceStatusToContentConverter x:Key="DeviceStatusToContentConverter"/>
        <base_convertor:DeviceStatusToEnableConvertor x:Key="DeviceStatusToEnableConvertor"/>
        <base_convertor:DeviceStatusToVisibilityConvertor x:Key="DeviceStatusToVisibilityConvertor"/>
        <base_convertor:DeviceStatusToBooleanConverter x:Key="DeviceStatusToBooleanConverter"/>
    </UserControl.Resources>
    <Grid>
        <Border Background="#80e6e6e6" CornerRadius="5" Height="150" VerticalAlignment="Top">
            <StackPanel>
                <Label FontWeight="Heavy" FontSize="21" Margin="0 10">激光位移传感器</Label>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="20 0">
                        <StackPanel Orientation="Horizontal">
                            <Label>I P :</Label>
                            <TextBox BorderBrush="Gray" BorderThickness="1"
                         Padding="1" MinWidth="100"
                         Text="{Binding PanasonicModbus.IP}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"></TextBox>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="31 0">
                            <Label>Port :</Label>
                            <TextBox BorderBrush="Gray" BorderThickness="1"
                         Padding="1" MinWidth="100"
                         Text="{Binding PanasonicModbus.Port}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"></TextBox>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="20 0">
                            <Button Width="100" Height="30"
                                Command="{Binding ConnectCommand}" CommandParameter="HL_G2"
                                Content="{Binding PanasonicModbus.DeviceStatus, Converter={StaticResource DeviceStatusToContentConverter}}"
                                IsEnabled="{Binding PanasonicModbus.DeviceStatus, Converter={StaticResource DeviceStatusToEnableConvertor}}"></Button>
                            <ProgressBar IsIndeterminate="True"
                                     Style="{StaticResource MaterialDesignCircularProgressBar}"
                                     Value="70" Margin="5 0"
                                     Visibility="{Binding PanasonicModbus.DeviceStatus, Converter={StaticResource DeviceStatusToVisibilityConvertor}}"></ProgressBar>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Margin="20 15" IsEnabled="{Binding PanasonicModbus.DeviceStatus, Converter={StaticResource DeviceStatusToBooleanConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <Label>零点偏置：</Label>
                            <Button Margin="5 0" Width="70" Height="30"
                                    Command="{Binding SetOffsetCommand}" CommandParameter="1">偏置</Button>
                            <Button Width="100" Height="30"
                                    Command="{Binding SetOffsetCommand}"  CommandParameter="0">恢复偏置</Button>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
