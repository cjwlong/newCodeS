<UserControl x:Class="Machine.Views.MachineStatus"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Machine.Views"
             xmlns:convertors="clr-namespace:Machine.Converters"
             xmlns:base_converter="clr-namespace:SharedResource.convertors;assembly=SharedResource"
             xmlns:base_enum="clr-namespace:SharedResource.enums;assembly=SharedResource"
             xmlns:enum="clr-namespace:Machine.Enums"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:sysCollection="clr-namespace:System.Collections;assembly=mscorlib"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:view_model="clr-namespace:Machine.ViewModels" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DataContext="{d:DesignInstance view_model:MachineStatusViewModel}" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <convertors:EnumDescriptionConverter x:Key="EnumConverter"/>
        <convertors:BooleanToColorConverter x:Key="BooleanToColorConverter"/>
        <convertors:ValueEqualConverter x:Key="ValueEqualConverter"/>
        <convertors:PositionErrorToColorConverter x:Key="PositionErrorToColorConverter"/>
        <convertors:MoveModeToVisibilityConverter x:Key="MoveModeConverter"/>
        <convertors:AxisName2VisibilityConverter x:Key="AxisName2VisibilityConverter"/>
        <base_converter:MultiBooleanToBooleanConverter x:Key="MultiBooleanToBooleanConverter"/>
        <base_converter:NullableBooleanToBooleanConverter x:Key="NullableBooleanToBooleanConverter"/>

        <sysCollection:ArrayList x:Key="RelComboBoxSource">
            <sys:Double>50</sys:Double>
            <sys:Double>10</sys:Double>
            <sys:Double>5</sys:Double>
            <sys:Double>1</sys:Double>
            <sys:Double>0.5</sys:Double>
            <sys:Double>0.1</sys:Double>
            <sys:Double>0.05</sys:Double>
            <sys:Double>0.01</sys:Double>
            <sys:Double>0.005</sys:Double>
            <sys:Double>0.0001</sys:Double>
        </sysCollection:ArrayList>

        <sysCollection:ArrayList x:Key="SpeedComboBoxSource">
            <sys:Double>0</sys:Double>
            <sys:Double>0.1</sys:Double>
            <sys:Double>0.25</sys:Double>
            <sys:Double>0.5</sys:Double>
            <sys:Double>0.75</sys:Double>
            <sys:Double>1.0</sys:Double>
            <sys:Double>1.5</sys:Double>
            <sys:Double>2.0</sys:Double>
        </sysCollection:ArrayList>

        <ObjectDataProvider x:Key="MoveModes" 
                  MethodName="GetValues"
                  ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="enum:MachineMoveMode"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>
    <Border BorderBrush="#4d4d4d" BorderThickness="0.5">
        <StackPanel>
            <Grid Margin="10,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="使能控制" FontSize="15" Width="80" Margin="10 0"
                       HorizontalAlignment="Left" VerticalAlignment="Center"></TextBlock>

                <TextBlock Text="轴位置" FontSize="15" Width="80" Margin="10 3"
                           Grid.Column="1"></TextBlock>

                <ComboBox x:Name="MoveMode" ItemsSource="{Binding Source={StaticResource MoveModes}}"
                      SelectedItem="{Binding CurrentMoveMode}"
                      FontSize="15" Grid.Column="2" 
                      Width="70"
                      Padding="1"
                      Height="25"
                      Margin="0 0 10 0"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      HorizontalAlignment="Right"  VerticalAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <ItemsControl ItemsSource="{Binding MachineVM.Axes}" x:Name="AxesPanel" Height="auto">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Height="auto">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.25*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" ToolTip="轴使能" Margin="20 0 0 0"
                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                FontStretch="Expanded" Padding="15 2"
                                IsEnabled="{Binding DataContext.MachineVM.DeviceStatus, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource ValueEqualConverter}, ConverterParameter={x:Static base_enum:DeviceStatus.Idle}}"
                                Content="{Binding Name}" Name="EnableButton" Command="{Binding ToggleEnable}" 
                                Background="{Binding Enabled, Converter={StaticResource BooleanToColorConverter}}"/>

                            <StackPanel Grid.Column="1" IsEnabled="{Binding DataContext.MachineVM.DeviceStatus, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource ValueEqualConverter}, ConverterParameter={x:Static base_enum:DeviceStatus.Idle}}">
                                <Grid MinHeight="3"></Grid>
                                <Border Background="Black" Height="auto" MaxWidth="250" CornerRadius="7" MinHeight="50">
                                    <TextBlock TextAlignment="Center" FontSize="25" Foreground="White"
                                               Text="{Binding DisplayPosition, StringFormat={}{0:F4}}" 
                                               VerticalAlignment="Center">
                                        <TextBlock.ToolTip>
                                            <StackPanel Orientation="Vertical">
                                                <TextBlock Text ="{Binding Position, StringFormat=机床坐标: {0:0.####}mm}" HorizontalAlignment="Left"/>
                                                <!--<TextBlock Text ="{Binding PositionError, StringFormat=位置误差: {0:0.####}mm}" HorizontalAlignment="Left"/>-->
                                            </StackPanel>
                                        </TextBlock.ToolTip>
                                                </TextBlock>
                                    <Border.ContextMenu>
                                        <ContextMenu Visibility="{Binding Name, Mode=OneWay, Converter={StaticResource AxisName2VisibilityConverter}}">
                                            <MenuItem Header="置零" Command="{Binding ZeroSettingCommand}"></MenuItem>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                </Border>
                                <Grid MinHeight="3"></Grid>
                            </StackPanel>


                            <Grid Grid.Column="2" Height="auto" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="20 0">
                                <StackPanel Orientation="Vertical" VerticalAlignment="Center" 
                                        Visibility="{Binding ElementName=MoveMode, Path=SelectedItem, Converter={StaticResource MoveModeConverter}, ConverterParameter=Absolute}">
                                    <TextBox Text="{Binding PtpTarget}" Margin="2" Padding="1" 
                                         InputMethod.IsInputMethodEnabled="False"
                                         HorizontalContentAlignment="Center" VerticalContentAlignment="Center" 
                                         Width="65" Height="auto" />
                                    <Button Content="移动" Command="{Binding ToPointCommand}" Padding="0"
                                        HorizontalAlignment="Center" Height="25" Width="65" >
                                        <Button.IsEnabled>
                                            <MultiBinding Converter="{StaticResource MultiBooleanToBooleanConverter}">
                                                <Binding Path="DataContext.MachineVM.DeviceStatus" 
                                                     RelativeSource="{RelativeSource AncestorType=UserControl}" 
                                                     Converter="{StaticResource ValueEqualConverter}"  
                                                     ConverterParameter="{x:Static base_enum:DeviceStatus.Idle}"/>
                                                <Binding Path="Enabled" 
                                                     Converter="{StaticResource NullableBooleanToBooleanConverter}"/>
                                            </MultiBinding>
                                        </Button.IsEnabled>
                                    </Button>
                                </StackPanel>
                                <StackPanel Orientation="Vertical" VerticalAlignment="Center" 
                                        Visibility="{Binding ElementName=MoveMode, Path=SelectedItem, Converter={StaticResource MoveModeConverter}, ConverterParameter=Relative}">
                                    <ComboBox Text="{Binding RelTarget}" 
                                          IsEditable="True" SelectedItem="1" 
                                          IsTextSearchEnabled="False" 
                                          Width="65" Height="auto" FontSize="12" 
                                          Margin="1" 
                                          VerticalContentAlignment="Center"
                                          ItemsSource="{Binding Source={StaticResource RelComboBoxSource}}"
                                              PreviewTextInput="ComboBox_PreviewTextInput">
                                    </ComboBox>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Height="25">
                                        <Button Content="-"  Width="30" Margin="0,1,2,1" Padding="0" Height="auto"
                                            Command="{Binding NegRelPointCommand}">
                                            <Button.IsEnabled>
                                                <MultiBinding Converter="{StaticResource MultiBooleanToBooleanConverter}">
                                                    <Binding Path="DataContext.MachineVM.DeviceStatus" 
                                                         RelativeSource="{RelativeSource AncestorType=UserControl}"
                                                         Converter="{StaticResource ValueEqualConverter}"  
                                                         ConverterParameter="{x:Static base_enum:DeviceStatus.Idle}"/>
                                                    <Binding Path="Enabled" 
                                                         Converter="{StaticResource NullableBooleanToBooleanConverter}"/>
                                                </MultiBinding>
                                            </Button.IsEnabled>
                                        </Button>
                                        <Button Content="+" Width="30" Margin="2,1,0,0" Height="auto" Padding="0"
                                            Command="{Binding PosRelPointCommand}" >
                                            <Button.IsEnabled>
                                                <MultiBinding Converter="{StaticResource MultiBooleanToBooleanConverter}">
                                                    <Binding Path="DataContext.MachineVM.DeviceStatus"
                                                         RelativeSource="{RelativeSource AncestorType=UserControl}" 
                                                         Converter="{StaticResource ValueEqualConverter}"  
                                                         ConverterParameter="{x:Static base_enum:DeviceStatus.Idle}"/>
                                                    <Binding Path="Enabled"
                                                         Converter="{StaticResource NullableBooleanToBooleanConverter}"/>
                                                </MultiBinding>
                                            </Button.IsEnabled>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>

</UserControl>
