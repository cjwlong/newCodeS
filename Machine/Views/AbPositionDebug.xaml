<UserControl x:Class="Machine.Views.AbPositionDebug"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Machine.Views"
             mc:Ignorable="d" 
                   xmlns:prism="http://prismlibrary.com/"

      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:base_convertors="clr-namespace:SharedResource.convertors;assembly=SharedResource"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <base_convertors:BooleanToOppositeConvertor x:Key="BooleanToOppositeConvertor"/>
        <!--<convertor:ReadonlyToVisibilityConvertor x:Key="ReadonlyToVisibilityConvertor"/>
        <convertor:PointModeToDisplayInfoConverter x:Key="PointModeToDisplayInfoConverter"/>-->
    </UserControl.Resources>
    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 左侧文件列表区域 -->
        <GroupBox Header="配置文件列表" Margin="10" Grid.Column="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBox Margin="5" Height="28" Width="190" Padding="5 1"
                          BorderThickness="1"
                          TextWrapping="Wrap"
                          Text="{Binding SearchText, Mode=TwoWay}"
                          HorizontalAlignment="Stretch" VerticalAlignment="Center"
                          materialDesign:HintAssist.Hint="搜索配置文件">
                    </TextBox>
                    <Button Height="25" Style="{StaticResource MaterialDesignOutlinedButton}"
                         Command="{Binding FindFileCommand}">搜索</Button>
                </StackPanel>


                <ListBox Grid.Row="1" Margin="10" 
              ItemsSource="{Binding FilteredConfigFiles}"
              SelectedItem="{Binding SelectedConfigFile}"
              HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Margin="5"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.Resources>
                        <ContextMenu x:Key="ItemContextMenu">
                            <MenuItem Header="应用" 
                                   Command="{Binding DataContext.ApplyCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                   CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            <MenuItem Header="删除" 
                           Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                           CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            <MenuItem Header="导出" Command="{Binding DataContext.OutputCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                 CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                            </MenuItem>
                        </ContextMenu>
                    </ListBox.Resources>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="ContextMenu" Value="{StaticResource ItemContextMenu}"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </GroupBox>

        <!-- 右侧内容区域 -->
        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 工具栏 -->
            <ToolBarTray Grid.Row="0">
            
            </ToolBarTray>
            <!--<StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Margin="5 0">
                <Button Content="导入" Command="{Binding InputCommand}"
                     Style="{StaticResource MaterialDesignRaisedLightButton}">
                </Button>
            </StackPanel>-->

            <!-- 配置内容区域 -->
            <Grid Grid.Column="1" Margin="10" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 工具栏 -->
                <ToolBarTray Grid.Row="0">
                    <ToolBar>
                        <Button Content="修改配置" Command="{Binding AmendCommand}" Margin="5,0">
                        </Button>
                        <Button Content="新建配置" Command="{Binding CreatCommand}" Margin="5,0">
                        </Button>
                        <Separator/>
                      
                    </ToolBar>
                </ToolBarTray>
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Margin="5 0">
                    <Button Content="导入" Command="{Binding InputCommand}"
                      Style="{StaticResource MaterialDesignRaisedLightButton}">
                    </Button>
                </StackPanel>

                <!-- 配置内容区域 -->
                <ScrollViewer  Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                    <StackPanel>
                        <Border BorderBrush="#c6c6c6" BorderThickness="1" CornerRadius="10" Margin="5">
                            <!--<Expander IsExpanded="True">-->
                                <!--<Expander.Header>-->
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <UniformGrid Rows="0">
                                        <TextBlock Margin="10 0 0 0" Text="点位设置" FontSize="17" VerticalAlignment="Center"/>
                                       
                                </UniformGrid>
                                <StackPanel Grid.Row="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <!-- 第一列固定 100px -->
                                            <ColumnDefinition Width="160"/>
                                            <!-- 第二列固定 200px -->
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <!-- 第三列占剩余 -->
                                        </Grid.ColumnDefinitions>

                                        <TextBlock VerticalAlignment="Center"  Width="60" Grid.Column="0">点位名称</TextBlock>
                                        <Border  Grid.Column="1" Background="#f1f1f1" CornerRadius="7" Margin="0 0 80 0" Height="40" Width="100">
                                            <TextBox BorderThickness="0" Margin="10 0" 
Text="{Binding CurrentPosition.Name}"/>
                                        </Border>
                                        <TextBlock   Grid.Column="2" VerticalAlignment="Center">点位模式：</TextBlock>
                                        <Label   Grid.Column="3" VerticalAlignment="Center" >绝对模式</Label>
                                    </Grid>

                                </StackPanel>
                                <!--</Expander.Header>-->
                                <StackPanel  Grid.Row="2">
                             
                                    <!--<StackPanel Margin="24 0 24 20">
                                  <TextBlock>点位描述</TextBlock>
                                  <Border Background="#f1f1f1" CornerRadius="7" Margin="0 10 30 0" Height="127">
                                      <TextBox BorderThickness="0" Padding="5 10"
                                               MaxLength="150"
                                               Height="127"
                                               BorderBrush="Transparent"
                                               VerticalScrollBarVisibility="Auto"
                                               AcceptsReturn="True"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Top"
                                               Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                  </Border>
                              </StackPanel>-->
                                    <UniformGrid Columns="5" Margin="24 -20 24 16">
                                        <TextBlock VerticalAlignment="Bottom" Text="x轴" Margin="0 3"/>
                                        <TextBlock VerticalAlignment="Bottom" Text="y轴" Margin="0 3"/>
                                        <TextBlock VerticalAlignment="Bottom" Text="z轴" Margin="0 3"/>
                                        <TextBlock VerticalAlignment="Bottom" Text="a轴" Margin="0 3"/>
                                        <TextBlock VerticalAlignment="Bottom" Text="c轴" Margin="0 3"/>
                                        <DockPanel >
                                            <Border Background="#f1f1f1" CornerRadius="7" Margin="0 0 30 0" Height="40">
                                                <TextBox BorderThickness="0" Margin="10 0"
                                                   Text="{Binding CurrentPosition.XPresetPlace}"/>
                                            </Border>
                                        </DockPanel>
                                        <DockPanel IsEnabled="{Binding IsReadonly, Converter={StaticResource BooleanToOppositeConvertor}}">
                                            <Border Background="#f1f1f1" CornerRadius="7" Margin="0 0 30 0" Height="40">
                                                <TextBox BorderThickness="0" Margin="10 0"
                                                   Text="{Binding CurrentPosition.YPresetPlace}"/>
                                            </Border>
                                        </DockPanel>
                                        <DockPanel IsEnabled="{Binding IsReadonly, Converter={StaticResource BooleanToOppositeConvertor}}">
                                            <Border Background="#f1f1f1" CornerRadius="7" Margin="0 0 30 0" Height="40">
                                                <TextBox BorderThickness="0" Margin="10 0"
                                                   Text="{Binding CurrentPosition.ZPresetPlace}"/>
                                            </Border>
                                        </DockPanel>
                                        <DockPanel IsEnabled="{Binding IsReadonly, Converter={StaticResource BooleanToOppositeConvertor}}">
                                            <Border Background="#f1f1f1" CornerRadius="7" Margin="0 0 30 0" Height="40">
                                                <TextBox BorderThickness="0" Margin="10 0"
                                                   Text="{Binding CurrentPosition.APresetPlace}"/>
                                            </Border>
                                        </DockPanel>
                                        <DockPanel IsEnabled="{Binding IsReadonly, Converter={StaticResource BooleanToOppositeConvertor}}">
                                            <Border Background="#f1f1f1" CornerRadius="7" Margin="0 0 30 0" Height="40">
                                                <TextBox BorderThickness="0" Margin="10 0"
                                                   Text="{Binding CurrentPosition.BPresetPlace}"/>
                                            </Border>
                                        </DockPanel>
                                        <Button Margin="0 0 30 0" Content="移动" Padding="5 0" 
                                          IsEnabled="{Binding IsReadonly}"
                                          Command="{Binding MoveAxisCommand}" 
                                          CommandParameter="X"/>
                                        <Button Margin="0 0 30 0" Content="移动" Padding="5 0" 
                                          IsEnabled="{Binding IsReadonly}"
                                          Command="{Binding MoveAxisCommand}" 
                                          CommandParameter="Y"/>
                                        <Button Margin="0 0 30 0" Content="移动" Padding="5 0" 
                                          IsEnabled="{Binding IsReadonly}"
                                          Command="{Binding MoveAxisCommand}" 
                                          CommandParameter="Z" />
                                        <Button Margin="0 0 30 0" Content="移动" Padding="5 0" 
                                          IsEnabled="{Binding IsReadonly}"
                                          Command="{Binding MoveAxisCommand}" 
                                          CommandParameter="A" />
                                        <Button Margin="0 0 30 0" Content="移动" Padding="5 0" 
                                          IsEnabled="{Binding IsReadonly}"
                                          Command="{Binding MoveAxisCommand}" 
                                          CommandParameter="B" />
                                    </UniformGrid>
                                </StackPanel>

                                <StackPanel Grid.Row="3">
                                    <Button HorizontalAlignment="Right" Content="保存" 
FontSize="15" Padding="10 0"
VerticalAlignment="Center"
Command="{Binding SaveCommand}"
CommandParameter="预设点位"
Style="{StaticResource MaterialDesignRaisedLightButton}"
IsEnabled="{Binding IsReadonly, Converter={StaticResource BooleanToOppositeConvertor}}"/>
                                </StackPanel>
                            </Grid>
                            <!--</Expander>-->
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
