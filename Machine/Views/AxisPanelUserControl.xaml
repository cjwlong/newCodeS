<UserControl x:Class="Machine.Views.AxisPanelUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Machine.Views"
             xmlns:convertor="clr-namespace:Machine.Converters"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:sysCollection="clr-namespace:System.Collections;assembly=mscorlib"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:base_enum="clr-namespace:SharedResource.enums;assembly=SharedResource"
             xmlns:view_model="clr-namespace:Machine.ViewModels" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DataContext="{d:DesignInstance view_model:AxisPanelUserControlViewModel}" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <convertor:LimitToBrushConverter x:Key="LimitToBrushConverter"/>
        <convertor:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
        <convertor:BoolToStatusConverter x:Key="BoolToStatusConverter"/>
        <convertor:ValueEqualConverter x:Key="ValueEqualConverter"/>

    </UserControl.Resources>
    <Border BorderBrush="#4d4d4d" BorderThickness="0.5">
        <Grid Margin="7"
              >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 顶部按钮区域 -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal">
                <Button Grid.Row="2" 
                        Content="设置" 
                        Command="{Binding SaveSelectedCommand}"/>
                <Grid Width="20"></Grid>
                <Button Content="回零" 
                        Command="{Binding HomeSelectedCommand}"/>
                <Grid  Width="10"></Grid>
                <TextBlock Text="位置：" VerticalAlignment="Center"/>
                <ComboBox Width="95" ItemsSource="{Binding PositionsType}" SelectedItem="{Binding CurrentPosition}" />
                <ComboBox Width="120" ItemsSource="{Binding Positions}" SelectedItem="{Binding StartPosition}"  IsEnabled="{Binding IsSecondEnabled}"/>
               
                <TextBlock Text="到" VerticalAlignment="Center"/>
                <ComboBox Width="110" ItemsSource="{Binding Positions}" SelectedItem="{Binding EndPosition}" />
                <Button Margin="5" Content="移动"  
         Command="{Binding MoveSelectedCommand}"/>
               
                <Grid Width="20"></Grid>
                <TextBlock Text="{Binding StatusMessage}" Foreground="DarkRed"
                           FontWeight="Bold"
                           Margin="10"
                           HorizontalAlignment="Left"/>
            </StackPanel>
            <!-- 数据表格区域 -->
            <DataGrid Grid.Row="1"
                      x:Name="RootPanel"
                        ItemsSource="{Binding MachineVM.Axes}" 
                        AutoGenerateColumns="False"
                        HeadersVisibility="Column"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch"
                        Background="White"
                        BorderBrush="LightGray"
                        BorderThickness="1"
                        Margin="-4 4 0 -4"
                       VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Hidden"
                      materialDesign:DataGridAssist.CellPadding="7 10"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="7 10">
                <DataGrid.Columns>
                    <!-- 选择列 -->
                    <DataGridTemplateColumn>
                        <DataGridTemplateColumn.Header>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox IsChecked="{Binding DataContext.IsAllSelected,
                                    RelativeSource={RelativeSource AncestorType=UserControl}, 
                                    Mode=TwoWay}"/>
                                <TextBlock Text="全选" 
                                           VerticalAlignment="Center" 
                                           Margin="1,0,0,0"/>
                            </StackPanel>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- 轴名称列 -->
                    <DataGridTextColumn Header="轴" 
                                        Binding="{Binding Name}" 
                                        IsReadOnly="True"
                                        Width="35"
                                        CanUserResize="False"
                                        CanUserReorder="False"
                                        CanUserSort="False"/>

                    <!-- 回零状态列 -->
                    <DataGridTemplateColumn Header="回零" Width="47" CanUserResize="False" 
                                            CanUserReorder="False"
                                            CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Fill="{Binding IsHomeed, Converter={StaticResource BoolToBrushConverter}}" Height="17" Width="17"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- 限位状态列 -->
                    <DataGridTemplateColumn Header="正限位" Width="55" 
                                            CanUserResize="False"
                                            CanUserReorder="False"
                                            CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Fill="{Binding RightLimit, Converter={StaticResource LimitToBrushConverter}}" Height="17" Width="17"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="负限位" Width="55" 
                                            CanUserResize="False"
                                            CanUserReorder="False"
                                            CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Fill="{Binding LeftLimit, Converter={StaticResource LimitToBrushConverter}}" Height="17" Width="17"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- 参数列 -->
                    <DataGridTextColumn Header="速度" 
                                        Binding="{Binding TempSpeed, StringFormat=F3, Mode=TwoWay}"
                                        Width="70" CanUserResize="False"
                                        CanUserReorder="False"
                                        CanUserSort="False"/>
                    <DataGridTextColumn Header="加速度" 
                                        Binding="{Binding TempAcceleratedSpeed, StringFormat=F3, Mode=TwoWay}"
                                        Width="70" 
                                        CanUserResize="False"
                                        CanUserReorder="False"
                                        CanUserSort="False"/>
                    <DataGridTextColumn Header="减速度" 
                                        Binding="{Binding TempDecelerationSpeed, StringFormat=F3, Mode=TwoWay}"
                                        Width="70" CanUserResize="False"
                                        CanUserReorder="False"
                                        CanUserSort="False"/>
                    <DataGridTextColumn Header="状态" Width="70" IsReadOnly="True"
                                        CanUserReorder="False"
                                        CanUserSort="False"
                                        Binding="{Binding HasUnsavedChanges, Converter={StaticResource BoolToStatusConverter}}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
    
</UserControl>
