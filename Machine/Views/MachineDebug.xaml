<UserControl x:Class="Machine.Views.MachineDebug"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Machine.Views"
             mc:Ignorable="d" 
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
              xmlns:controls="clr-namespace:Machine.Controls"
              xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Notes Section -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="备注: 1. 必须是纯英文，不允许有中文;"
                FontSize="12" 
                Foreground="Gray"
                Margin="0,0,0,5"/>
            <TextBlock Text="        2. 英文 '!'是注释符" 
                FontSize="12" 
                Foreground="Gray"/>
        </StackPanel>

        <!-- Main Text Input Area with Line Numbers -->
        <controls:LineNumberedTextBox Grid.Row="1"  BorderThickness="1"
                 Text="{Binding MainText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                 Margin="0,5,0,5"
                 x:Name="MainTextBox" />

        <!-- Bottom Section: Input Field and Buttons -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Small Input Field -->
            <TextBox Grid.Column="0" 
                     Text="{Binding InputText}"
                     Height="30"
                     VerticalContentAlignment="Center"
                     Padding="5"
                     Margin="0,0,10,0"
                     BorderBrush="LightGray"
                     BorderThickness="1"/>

            <!-- Upload Button -->
            <Button Grid.Column="1" 
                    Content="上传" 
                    Command="{Binding UploadCommand}"
                    Width="80"
                    Height="30"
                    Margin="0,0,10,0"
                    Padding="10,0"/>

            <!-- Execute Button -->
            <Button Grid.Column="2" 
                    Content="执行" 
                    
                    Command="{Binding ExecuteCommand}"
                    Width="80"
                    Height="30"
                    Padding="10,0"/>
        </Grid>
    </Grid>
</UserControl>
