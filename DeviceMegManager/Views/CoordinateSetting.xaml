<UserControl x:Class="DeviceMegManager.Views.CoordinateSetting"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DeviceMegManager.Views"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             FontSize="16"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Border Background="#80e6e6e6" CornerRadius="5" Height="190" VerticalAlignment="Top">
            <UniformGrid Rows="3" Height="170" VerticalAlignment="Top">
                <Grid VerticalAlignment="Center" HorizontalAlignment="Center"></Grid>
                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center">X轴</TextBlock>
                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center">Y轴</TextBlock>
                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center">Z轴</TextBlock>
                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center">振镜</TextBlock>
                <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBox MinWidth="100"></TextBox>
                        <Button BorderThickness="0" Style="{StaticResource MaterialDesignIconForegroundButton}" Padding="0">
                            <materialDesign:PackIcon Kind="MapMarkerRadiusOutline" Height="30" Width="30"/>
                        </Button>
                    </StackPanel>
                </Grid>
                <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBox MinWidth="100"></TextBox>
                        <Button BorderThickness="0" Padding="0" Style="{StaticResource MaterialDesignIconForegroundButton}">
                            <materialDesign:PackIcon Kind="MapMarkerRadiusOutline" Height="30" Width="30"/>
                        </Button>
                    </StackPanel>
                </Grid>
                <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBox MinWidth="100"></TextBox>
                        <Button BorderThickness="0" Style="{StaticResource MaterialDesignIconForegroundButton}" Padding="0">
                            <materialDesign:PackIcon Kind="MapMarkerRadiusOutline" Height="30" Width="30"/>
                        </Button>
                    </StackPanel>
                </Grid>
                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center">相机</TextBlock>
                <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBox MinWidth="100"></TextBox>
                        <Button BorderThickness="0" Style="{StaticResource MaterialDesignIconForegroundButton}" Padding="0">
                            <materialDesign:PackIcon Kind="MapMarkerRadiusOutline" Height="30" Width="30"/>
                        </Button>
                    </StackPanel>
                </Grid>
                <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBox MinWidth="100"></TextBox>
                        <Button BorderThickness="0" Style="{StaticResource MaterialDesignIconForegroundButton}" Padding="0">
                            <materialDesign:PackIcon Kind="MapMarkerRadiusOutline" Height="30" Width="30"/>
                        </Button>
                    </StackPanel>
                </Grid>
                <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBox MinWidth="100"></TextBox>
                        <Button BorderThickness="0" Style="{StaticResource MaterialDesignIconForegroundButton}" Padding="0">
                            <materialDesign:PackIcon Kind="MapMarkerRadiusOutline" Height="30" Width="30"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </UniformGrid>
        </Border>            
    </Grid>
</UserControl>
