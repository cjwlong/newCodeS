<UserControl x:Class="DeviceMegManager.Views.DeviceMeg"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:DeviceMegManager.Views"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border BorderThickness="1" 
    BorderBrush="#4d4d4d" 
    CornerRadius="5" 
    Background="#f9f9f9"
    Effect="{StaticResource CardShadowEffect}">
        <StackPanel>
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Margin="0 7 0 0">设备信息</TextBlock>
            
            <StackPanel Orientation="Horizontal">
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" Width="100">激光出口功率：</TextBlock>
                <TextBox Margin="7 7 7 4" Width="75" IsReadOnly="True"
                         Background="#bababa"
                         FontSize="13"
                         Text="{Binding bLLaser.LaserPower, Mode=OneWay}"></TextBox>
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" Width="25">W</TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                   Margin="10 0 0 0" Width="100">激光目标功率：</TextBlock>
                <TextBox Margin="7 7 7 4" Width="75" IsReadOnly="True"
                 Background="#bababa"
                 FontSize="13"
                 Text="{Binding bLLaser.PowerFactor, Mode=OneWay}"></TextBox>
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                   Margin="10 0 0 0" Width="25">%</TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" MinWidth="100">激光频率：</TextBlock>
                <TextBox Margin="7 4" Width="75" IsReadOnly="True"
                         Background="#bababa"
                         FontSize="13"
                         Text="{Binding bLLaser.BaseFreq, Mode=OneWay}"></TextBox>
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" Width="25">kHz</TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" MinWidth="100">激光器温度：</TextBlock> 
                <TextBox Margin="7 4" Width="75" IsReadOnly="True"
                         Background="#bababa"
                         Text="{Binding bLLaser.LaserHead, Mode=OneWay}"></TextBox>
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" Width="25">℃</TextBlock>
            </StackPanel>

            <!--<StackPanel Orientation="Horizontal">
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" MinWidth="100">激光测距距离：</TextBlock>
                <TextBox Margin="7 4" Width="75" IsReadOnly="True"
                         Background="#bababa"
                         FontSize="13"
                         Text="{Binding hL_G2_Ranger.PanasonicModbusValue, Mode=OneWay, StringFormat=F4}"></TextBox>
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" Width="25">mm</TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" MinWidth="100">接触式测距距离：</TextBlock>
                <TextBox Margin="7 4" MinWidth="75" IsReadOnly="True"
                         Background="#bababa"
                         FontSize="13"
                         Text="{Binding mitutoyo_EJ_Ranger.LGQuickValue, Mode=OneWay, StringFormat=F4}"></TextBox>
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" Width="25">mm</TextBlock>
            </StackPanel>-->
        </StackPanel>
    </Border>
</UserControl>
