<UserControl x:Class="DeviceMegManager.Views.DeviceStatusControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DeviceMegManager.Views"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:base_convertors="clr-namespace:SharedResource.convertors;assembly=SharedResource"
             xmlns:convertor="clr-namespace:DeviceMegManager.convertors"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <convertor:DeviceStatusConvertor x:Key="DeviceStatusConvertor"/>
        <base_convertors:DeviceStatusToEnableConvertor x:Key="DeviceStatusToEnableConvertor"/>
        <base_convertors:Laserstatus2BtnStatusConvertor x:Key="Laserstatus2BtnStatusConvertor"/>
        <convertor:DeviceStatus2colorConvertor x:Key="DeviceStatus2colorConvertor"/>
        <convertor:Connecting2colorConvertor x:Key="Connecting2colorConvertor"/>
    </UserControl.Resources>
    <Border BorderBrush="#4d4d4d" BorderThickness="0.5">
        <UniformGrid Columns="2">
            <Border Margin="25 2" CornerRadius="14" BorderThickness="1" BorderBrush="#8a8a8a" IsEnabled="{Binding Machine.DeviceStatus, Mode=OneWay, Converter={StaticResource DeviceStatusToEnableConvertor}}"
                    Background="{Binding Machine.DeviceStatus, Mode=OneWay, Converter={StaticResource DeviceStatus2colorConvertor}}">                
                <UniformGrid Rows="1" Width="150">
                    <materialDesign:PackIcon Width="24" Height="24" Kind="BenchBack" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14">运动机床</TextBlock>
                </UniformGrid>
                <Border.ContextMenu>
                    <ContextMenu Padding="1" Background="#bababa">
                        <MenuItem Header="{Binding Machine.DeviceStatus, Mode=OneWay, Converter={StaticResource DeviceStatusConvertor}}"
                                  Command="{Binding DeviceConnectCommand}" CommandParameter="运动机床" Padding="17 1">
                        </MenuItem>
                    </ContextMenu>
                </Border.ContextMenu>
            </Border>
            <Border Margin="25 2" CornerRadius="14" BorderThickness="1" BorderBrush="#8a8a8a" IsEnabled="{Binding bLLaser.Connecting, Mode=OneWay, Converter={StaticResource Laserstatus2BtnStatusConvertor}, ConverterParameter=connecting}"
                    Background="{Binding bLLaser.IsConnected, Mode=OneWay, Converter={StaticResource DeviceStatus2colorConvertor}}">
                <Border CornerRadius="14" BorderThickness="1" Margin="-0.7"
                        Background="{Binding bLLaser.Connecting, Mode=OneWay, Converter={StaticResource Connecting2colorConvertor}}">
                    <UniformGrid Rows="1" Width="150">
                        <materialDesign:PackIcon Width="24" Height="24" Kind="Printer3dNozzle"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14">激光器</TextBlock>
                    </UniformGrid>
                    <Border.ContextMenu>
                        <ContextMenu Padding="1" Background="#bababa">
                            <MenuItem Header="{Binding bLLaser.IsConnected, Mode=OneWay, Converter={StaticResource DeviceStatusConvertor}}"
                                      Command="{Binding DeviceConnectCommand}" CommandParameter="激光器" Padding="17 1">
                            </MenuItem>
                        </ContextMenu>
                    </Border.ContextMenu>
                </Border>                
            </Border>
            <Border Margin="25 2" CornerRadius="14" BorderThickness="1" BorderBrush="#8a8a8a"
                    Background="{Binding CameraState, Mode=OneWay, Converter={StaticResource DeviceStatus2colorConvertor}}">
                <UniformGrid Rows="1" Width="150">
                    <materialDesign:PackIcon Width="24" Height="24" Kind="Camera"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14">相机</TextBlock>
                </UniformGrid>
                <Border.ContextMenu>
                    <ContextMenu Padding="1" Background="#bababa">
                        <MenuItem Header="{Binding CameraState, Mode=OneWay, Converter={StaticResource DeviceStatusConvertor}}"
                                  Command="{Binding DeviceConnectCommand}" CommandParameter="相机" Padding="17 1">
                        </MenuItem>
                    </ContextMenu>
                </Border.ContextMenu>
            </Border>
            <Border Margin="25 2" CornerRadius="14" BorderThickness="1" BorderBrush="#8a8a8a" IsEnabled="{Binding hL_G2_Ranger.DeviceStatus, Converter={StaticResource DeviceStatusToEnableConvertor}}"
                    Background="{Binding hL_G2_Ranger.DeviceStatus, Mode=OneWay, Converter={StaticResource DeviceStatus2colorConvertor}}">
                <UniformGrid Rows="1" Width="150">
                    <materialDesign:PackIcon Width="24" Height="24" Kind="Toslink"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14">激光测距仪</TextBlock>
                </UniformGrid>
                <Border.ContextMenu>
                    <ContextMenu Padding="1" Background="#bababa">
                        <MenuItem Header="{Binding hL_G2_Ranger.DeviceStatus, Mode=OneWay, Converter={StaticResource DeviceStatusConvertor}}"
                                  Command="{Binding DeviceConnectCommand}" CommandParameter="激光测距仪" Padding="17 1">
                        </MenuItem>
                    </ContextMenu>
                </Border.ContextMenu>
            </Border>
            <Border Margin="25 2" CornerRadius="14" BorderThickness="1" BorderBrush="#8a8a8a" IsEnabled="{Binding mitutoyo_EJ_Ranger.DeviceStatus, Converter={StaticResource DeviceStatusToEnableConvertor}}"
                    Background="{Binding mitutoyo_EJ_Ranger.DeviceStatus, Mode=OneWay, Converter={StaticResource DeviceStatus2colorConvertor}}">
                <UniformGrid Rows="1" Width="165">
                    <materialDesign:PackIcon Width="24" Height="24" Kind="Timeline"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14">接触式测距仪</TextBlock>
                </UniformGrid>
                <Border.ContextMenu>
                    <ContextMenu Padding="1" Background="#bababa">
                        <MenuItem Header="{Binding mitutoyo_EJ_Ranger.DeviceStatus, Mode=OneWay, Converter={StaticResource DeviceStatusConvertor}}"
                                  Command="{Binding DeviceConnectCommand}" CommandParameter="接触式测距仪" Padding="17 1">
                        </MenuItem>
                    </ContextMenu>
                </Border.ContextMenu>
            </Border>
            <Border Margin="25 2" CornerRadius="14" BorderThickness="1" BorderBrush="#8a8a8a" IsEnabled="{Binding ioDeviceService.DeviceStatus, Converter={StaticResource DeviceStatusToEnableConvertor}}"
                    Background="{Binding ioDeviceService.DeviceStatus, Mode=OneWay, Converter={StaticResource DeviceStatus2colorConvertor}}">
                <UniformGrid Rows="1" Width="165">
                    <materialDesign:PackIcon Width="24" Height="24" Kind="Timeline"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14">IO设备</TextBlock>
                </UniformGrid>
                <Border.ContextMenu>
                    <ContextMenu Padding="1" Background="#bababa">
                        <MenuItem Header="{Binding ioDeviceService.DeviceStatus, Mode=OneWay, Converter={StaticResource DeviceStatusConvertor}}"
                                  Command="{Binding DeviceConnectCommand}" CommandParameter="IO设备" Padding="17 1">
                        </MenuItem>
                    </ContextMenu>
                </Border.ContextMenu>
            </Border>
        </UniformGrid>
    </Border>
</UserControl>
