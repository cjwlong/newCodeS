<UserControl x:Class="ProductManage.Views.ProductMeg"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProductManage.Views"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border BorderThickness="1" 
    BorderBrush="#4d4d4d" 
    CornerRadius="5" 
    Background="#f9f9f9"
    Effect="{StaticResource CardShadowEffect}">
        <StackPanel>
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Margin="0 7 0 0">加工信息</TextBlock>
            
            <StackPanel Orientation="Horizontal">
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" MinWidth="110">当前加工产品名称：</TextBlock>
                <TextBox Margin="7" MinWidth="75" IsReadOnly="True"
                         Background="#bababa"
                         FontSize="13"
                         Text="{Binding globalCraftPara.FileName}"></TextBox>
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" Width="25"></TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" MinWidth="110">当前加工产品尺寸：</TextBlock>
                <TextBox Margin="7" MinWidth="75" IsReadOnly="True"
                         Background="#bababa"
                         FontSize="13"
                         Text="{Binding globalCraftPara.BallDiameter}"></TextBox>
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" Width="25">mm</TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" MinWidth="110">当前工艺参数：</TextBlock>
                <TextBox Margin="7" MinWidth="75" IsReadOnly="True"
                         Background="#bababa"
                         FontSize="13"
                         Text="{Binding globalCraftPara.FileName}"></TextBox>
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" Width="25"></TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" MinWidth="110">当前CPU利用率：</TextBlock>
                <TextBox Margin="7" Width="75" IsReadOnly="True"
                         Text="{Binding CpuUsage, StringFormat={}{0:F1}%}"
                         FontSize="13"
                         Background="#bababa"></TextBox>
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" Width="25"></TextBlock>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
