<UserControl x:Class="ProductManage.Views.ProductionMeg"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProductManage.Views"
      xmlns:prism="http://prismlibrary.com/"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      prism:ViewModelLocator.AutoWireViewModel="True"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800">
    <Border BorderThickness="1"
            BorderBrush="#4d4d4d" 
            CornerRadius="5" 
            Background="#f9f9f9"
            Effect="{StaticResource CardShadowEffect}">
        <StackPanel>
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Margin="0 7 0 0">产品信息</TextBlock>
            
            <StackPanel Orientation="Horizontal">
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" MinWidth="110">当前产品加工时间：</TextBlock>
                <TextBox Margin="7 7 7 4" Width="75" IsReadOnly="True"
                         Background="#bababa"
                         FontSize="13"
                         Text="{Binding CurrentProcessingTime, Mode=OneWay}"></TextBox>
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" Width="15">S</TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" MinWidth="110">当前产品空闲时间：</TextBlock>
                <TextBox Margin="7 4" Width="75" IsReadOnly="True"
                         Background="#bababa"
                         Text="{Binding CurrentIdleTime, Mode=OneWay}"></TextBox>
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" Width="15">S</TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" MinWidth="110">总共生产产品：</TextBlock>
                <TextBox Margin="7 4" Width="75" IsReadOnly="True"
                         Background="#bababa"
                         FontSize="13"
                         Text="{Binding TotalProductCount, Mode=OneWay}"></TextBox>
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" Width="15">个</TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" MinWidth="110">总共生产时间：</TextBlock>
                <TextBox Margin="7 4" Width="75" IsReadOnly="True"
                         Background="#bababa"
                         Text="{Binding TotalProcessingTime, Mode=OneWay}"></TextBox>
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" Width="15">S</TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" MinWidth="110">总共空闲时间：</TextBlock>
                <TextBox Margin="7 4" Width="75" IsReadOnly="True"
                         Background="#bababa"
                         FontSize="13"
                         Text="{Binding TotalIdleTime, Mode=OneWay}"></TextBox>
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="10 0 0 0" Width="15">S</TextBlock>
            </StackPanel>
        </StackPanel>
    </Border>    
</UserControl>
