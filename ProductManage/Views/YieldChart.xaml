        <Border Padding="10" Background="#F9F9F9" Grid.Row="1">
            <Grid  
    MinHeight="180">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="25*"/>
                    <ColumnDefinition Width="63*"/>
                </Grid.ColumnDefinitions>
                <local1:SimpleChart
