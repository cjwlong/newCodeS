    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 按钮面板保持不变 -->
        <StackPanel Orientation="Horizontal" Cursor=""  Grid.Row="0">
            <Button Content="采集" Width="60" Command="{Binding StartCommand}" Height="25"/>
            <Button Content="计算" Width="60" Command="{Binding CalculateCommand}" Height="25"/>
            <Button Content="绘图" Width="60" Command="{Binding StopCommand}"  Height="25"/>
            <Button Content="清空" Width="60" Command="{Binding ClearCommand}" Height="25"/>
            <Button Content="导出CSV" Width="90" Command="{Binding ExportCsvCommand}"  Height="25"/>
            <TextBlock Text="正在测试中..." 
                       Foreground="OrangeRed"
                       Margin="15,0,0,0"
                       VerticalAlignment="Center"
                       Visibility="{Binding IsTesting, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>

