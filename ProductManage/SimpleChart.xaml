<UserControl x:Class="ProductManage.SimpleChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProductManage"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="White" >

    <Grid >
        <!-- X 方向滚动 -->
        <ScrollViewer x:Name="ScrollViewerX"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">

            <Canvas x:Name="ChartCanvas"
                    Background="White"
                    MouseMove="ChartCanvas_MouseMove"
                    MouseLeave="ChartCanvas_MouseLeave"/>
        </ScrollViewer>
    </Grid>
</UserControl>
