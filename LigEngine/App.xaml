<prism:PrismApplication x:Class="LigEngine.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LigEngine"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:prism="http://prismlibrary.com/" >
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:CustomColorTheme BaseTheme="Light" PrimaryColor="#8a8a8a" SecondaryColor="#525752"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.PopupBox.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.SplitButton.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 阴影效果 -->
            <DropShadowEffect x:Key="CardShadowEffect" 
                  BlurRadius="5" 
                  ShadowDepth="1" 
                  Opacity="0.15" 
                  Color="#000000"/>
        </ResourceDictionary>
    </Application.Resources>
</prism:PrismApplication>
