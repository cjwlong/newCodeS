<UserControl x:Class="RangeFinderManager.Views.ContactRangeSetting"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:base_convertor="clr-namespace:SharedResource.convertors;assembly=SharedResource"
             xmlns:local="clr-namespace:RangeFinderManager.Views"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             FontSize="16"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <base_convertor:DeviceStatusToContentConverter x:Key="DeviceStatusToContentConverter"/>
        <base_convertor:DeviceStatusToEnableConvertor x:Key="DeviceStatusToEnableConvertor"/>
        <base_convertor:DeviceStatusToVisibilityConvertor x:Key="DeviceStatusToVisibilityConvertor"/>
        <base_convertor:DeviceStatusToBooleanConverter x:Key="DeviceStatusToBooleanConverter"/>
    </UserControl.Resources>
    <Grid>
        <Border Background="#80e6e6e6" CornerRadius="5" Height="110" VerticalAlignment="Top">
            <StackPanel>
                <Label FontWeight="Heavy" FontSize="21" Margin="0 10">接触式测距仪</Label>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="20 0">
                        <StackPanel Orientation="Horizontal">
                            <Label HorizontalAlignment="Center" VerticalAlignment="Center">串口:</Label>
                            <ComboBox MinWidth="100" Height="35" Padding="1" 
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding MitutoyoEJRanger.COMs}"
                                      SelectedItem="{Binding MitutoyoEJRanger.NowCom}"></ComboBox>
                            <Button Command="{Binding RefreshPortConnectCommand}" 
                                    Background="Transparent"
                                    BorderThickness="1"
                                    BorderBrush="#272727">刷新</Button>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="20 0">
                            <Label HorizontalAlignment="Center" VerticalAlignment="Center">波特率:</Label>
                            <ComboBox MinWidth="100" Height="35" Padding="1"  
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding BaudRateLists}" 
                                      SelectedItem="{Binding MitutoyoEJRanger.BaudRate}"></ComboBox>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="20 0">
                            <Button Width="100" Height="30"
                                    Command="{Binding RangerConnectCommand}"
                                    Content="{Binding MitutoyoEJRanger.DeviceStatus, Converter={StaticResource DeviceStatusToContentConverter}}"
                                    IsEnabled="{Binding MitutoyoEJRanger.DeviceStatus, Converter={StaticResource DeviceStatusToEnableConvertor}}"></Button>
                            <ProgressBar IsIndeterminate="True"
                                         Style="{StaticResource MaterialDesignCircularProgressBar}"
                                         Value="70" Margin="5 0"
                                         Visibility="{Binding MitutoyoEJRanger.DeviceStatus, Converter={StaticResource DeviceStatusToVisibilityConvertor}}"></ProgressBar>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
