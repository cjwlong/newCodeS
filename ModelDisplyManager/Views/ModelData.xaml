    <Border BorderThickness="1" 
BorderBrush="#4d4d4d" 
CornerRadius="5" 
Background="#f9f9f9"
Effect="{StaticResource CardShadowEffect}" Margin="2 0 2 2">

        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- 标题 -->
                <RowDefinition Height="30"/>
                <!-- 间距 -->

                <RowDefinition Height="Auto"/>
                <!-- 文本1 -->
                <RowDefinition Height="Auto"/>
                <!-- 输入框1 -->

                <RowDefinition Height="40"/>
                <!-- 间距 -->

                <RowDefinition Height="Auto"/>
                <!-- 文本2 -->
                <RowDefinition Height="Auto"/>
                <!-- 输入框2 -->
            </Grid.RowDefinitions>

            <!-- 第一行：标题 -->
            <TextBlock Grid.Row="0"
                   Text="实时测量信息"
                   FontSize="28"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>


            <!-- 第二行：文字 -->
            <TextBlock Grid.Row="2"
                   Text="激光测距距离(mm)："  Height="30"  Margin="5"
                   FontSize="22"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"/>

            <!-- 第三行：文本框 -->
            <TextBox Grid.Row="3" Width="240"
                 Height="90"
                 FontSize="50"
                 Margin="0 10 0 0" 
                 VerticalAlignment="Center" IsReadOnly="True"
                     Background="#bababa"
                     
                     Text="{Binding hL_G2_Ranger.PanasonicModbusValue, Mode=OneWay, StringFormat=F4}"/>


            <!-- 第四行：文字 -->
            <TextBlock Grid.Row="5"
                   Text="接触式测距距离(mm）：" Height="30" Margin="5 0 0 2"
                   FontSize="22"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"/>

            <!-- 第五行：文本框 -->
            <TextBox Grid.Row="6"
                 Height="90" Width="240"
                 FontSize="50"
                 Margin="0 10 0 0"
                 VerticalAlignment="Center" IsReadOnly="True"
                     Background="#bababa"
                
                     Text="{Binding mitutoyo_EJ_Ranger.LGQuickValue, Mode=OneWay, StringFormat=F4}"/>

        </Grid>
    </Border>
</UserControl>
