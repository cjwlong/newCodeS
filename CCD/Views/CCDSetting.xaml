<UserControl x:Class="CCD.Views.CCDSetting"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CCD.Views" 
             xmlns:convert="clr-namespace:CCD.convertors"
             xmlns:base_convertor="clr-namespace:SharedResource.convertors;assembly=SharedResource"
             xmlns:tools="clr-namespace:CCD.tools"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             FontSize="16"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <base_convertor:BooleanToContentConvertor x:Key="BooleanToContentConvertor"/>
        <convert:CalibrationStatusConverter x:Key="calibrationStatus" />
        <convert:CameraStatusToPauseButtonEnabledConverter x:Key="CameraStatusToPauseButtonEnabledConverter" />
        <convert:CameraStatusToBtnContentConvertor x:Key="CameraStatusToBtnContentConvertor" />
    </UserControl.Resources>
    <Grid>
        <Border Background="#80e6e6e6" CornerRadius="5" Height="100" VerticalAlignment="Top">
            <StackPanel>
                <Label FontWeight="Heavy" FontSize="21" Margin="0 10">相机连接</Label>

                <StackPanel Orientation="Horizontal" Margin="20 0">
                    <StackPanel Orientation="Horizontal">
                        <Label VerticalAlignment="Center">相机标定状态：</Label>
                        <TextBox BorderBrush="Gray" BorderThickness="1"
                                 Padding="1"
                                 IsReadOnly="True"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding Source={x:Static tools:CoordinateHelper.Instance}, Path=Calibration, Converter={StaticResource calibrationStatus},StringFormat='相机: {0}'}"></TextBox>
                        <Button Margin="20 0" Command="{Binding InputCalibrationCommand}">导入标定文件</Button>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="20 0">
                        <Button Width="100"
                                Command="{Binding CameraConnectedCommand}"
                                Content="{Binding CameraState, Mode=OneWay, Converter={StaticResource CameraStatusToBtnContentConvertor}}">                            
                        </Button>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
